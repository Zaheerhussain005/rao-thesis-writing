{
  "// note": "Forces LaTeX Workshop to use XeLaTeX + BibTeX (required by fontspec).",

  "// path-note": "Absolute paths to MiKTeX so it works even though VS Code's PATH lacks the MiKTeX bin folder.",

  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "C:/Users/ADNAN/AppData/Local/Programs/MiKTeX/miktex/bin/x64/xelatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "bibtex",
      "command": "C:/Users/ADNAN/AppData/Local/Programs/MiKTeX/miktex/bin/x64/bibtex.exe",
      "args": ["%DOCFILE%"]
    }
  ],

  "latex-workshop.latex.recipes": [
    {
      "name": "XeLaTeX + BibTeX",
      "tools": ["xelatex", "bibtex", "xelatex", "xelatex"]
    },
    {
      "name": "XeLaTeX (no bib)",
      "tools": ["xelatex"]
    }
  ],

  "latex-workshop.latex.recipe.default": "XeLaTeX + BibTeX",

  "latex-workshop.latex.outDir": "%DIR%",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",

  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.lof", "*.lot",
    "*.out", "*.toc", "*.acn", "*.acr", "*.alg", "*.glg", "*.glo",
    "*.gls", "*.fls", "*.log", "*.fdb_latexmk", "*.snm", "*.nav",
    "*.synctex.gz"
  ]
}
